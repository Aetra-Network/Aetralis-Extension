{
  "Aetralis Contract": {
    "prefix": "atlx-contract",
    "description": "Insert a contract skeleton",
    "body": [
      "contract ${1:Counter} {",
      "  author: \"${2:Author}\"",
      "  description: \"${3:Description}\"",
      "  version: \"${4:0.1.0}\"",
      "",
      "  storage: ${5:Storage}",
      "  incomingMessages: ${6:InternalMsg}",
      "  incomingExternal: ${7:ExternalMsg}",
      "",
      "  @store",
      "  func ${8:Storage}.load() {",
      "    return ${8:Storage}.fromChunk(contract.getData())",
      "  }",
      "}"
    ]
  },
  "Aetralis Type Alias": {
    "prefix": "atlx-type",
    "description": "Insert a type alias",
    "body": [
      "type ${1:CounterValue} = ${2:int64}"
    ]
  },
  "Aetralis Struct": {
    "prefix": "atlx-struct",
    "description": "Insert a struct definition",
    "body": [
      "struct ${1:MyStruct} {",
      "  ${2:field}: ${3:uint32}",
      "}"
    ]
  },
  "Aetralis Function": {
    "prefix": "atlx-func",
    "description": "Insert a function",
    "body": [
      "func ${1:helper}(${2:value}: ${3:int64}) -> ${4:int64} {",
      "  return ${2:value}",
      "}"
    ]
  },
  "Aetralis Internal": {
    "prefix": "atlx-internal",
    "description": "Insert an internal handler",
    "body": [
      "@internal",
      "func onInternalMessage(in: InMessage) {",
      "  $0",
      "}"
    ]
  },
  "Aetralis External": {
    "prefix": "atlx-external",
    "description": "Insert an external handler",
    "body": [
      "@external(inMsg: Segment)",
      "func onExternalMessage(inMsg: Segment) {",
      "  $0",
      "}"
    ]
  },
  "Aetralis Bounced": {
    "prefix": "atlx-bounced",
    "description": "Insert a bounced handler",
    "body": [
      "@bounced",
      "func onBouncedMessage(in: InMessageBounced) {",
      "  $0",
      "}"
    ]
  },
  "Aetralis Create Message": {
    "prefix": "createMessage",
    "description": "Insert a createMessage call",
    "body": [
      "createMessage({",
      "  bounce: ${1:BounceMode.Only256BitsOfBody},",
      "  value: ${2:0},",
      "  dest: ${3:target},",
      "  body: ${4:payload}",
      "})"
    ]
  }
}
