{
  "name": "aetralis-language",
  "displayName": "Aetralis Language",
  "description": "Language extension for Aetralis smart contract development on the Aetra blockchain.",
  "version": "0.1.5",
  "publisher": "softwaremaestro",
  "repository": {
    "type": "git",
    "url": "https://github.com/Aetra-Network/Aetralis-Extension.git"
  },
  "bugs": {
    "url": "https://github.com/Aetra-Network/Aetralis-Extension/issues"
  },
  "homepage": "https://github.com/Aetra-Network/Aetralis-Extension#readme",
  "icon": "./assets/aetralis.png",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "aetralis",
    "atlx",
    "smart-contracts",
    "blockchain",
    "syntax-highlighting"
  ],
  "activationEvents": [
    "onLanguage:atlx"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "atlx",
        "aliases": [
          "Aetralis",
          "ATLX"
        ],
        "extensions": [
          ".atlx"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "atlx",
        "scopeName": "source.atlx",
        "path": "./syntaxes/atlx.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "atlx",
        "path": "./snippets/atlx.json"
      }
    ],
    "semanticTokenTypes": [
      {
        "id": "annotation",
        "superType": "decorator",
        "description": "Aetralis annotation token."
      },
      {
        "id": "contractKeyword",
        "superType": "keyword",
        "description": "The contract keyword."
      },
      {
        "id": "typeKeyword",
        "superType": "keyword",
        "description": "The type or struct keyword."
      },
      {
        "id": "storageKeyword",
        "superType": "keyword",
        "description": "The const, var, or val keyword."
      },
      {
        "id": "metadataKeyword",
        "superType": "keyword",
        "description": "The author, description, or version keyword."
      },
      {
        "id": "controlKeyword",
        "superType": "keyword",
        "description": "A control-flow keyword."
      },
      {
        "id": "functionKeyword",
        "superType": "keyword",
        "description": "The func keyword."
      },
      {
        "id": "contractName",
        "superType": "class",
        "description": "A contract symbol."
      },
      {
        "id": "builtin",
        "superType": "function",
        "description": "A built-in runtime helper."
      },
      {
        "id": "constant",
        "superType": "variable",
        "description": "A named constant or literal-like symbol."
      },
      {
        "id": "messageName",
        "superType": "enumMember",
        "description": "A message variant name."
      }
    ],
    "semanticTokenScopes": [
      {
        "scopes": {
          "annotation": ["storage.type.annotation.atlx"],
          "contractKeyword": ["keyword.declaration.contract.atlx"],
          "typeKeyword": ["keyword.declaration.type.atlx"],
          "storageKeyword": ["keyword.declaration.storage.atlx"],
          "metadataKeyword": ["keyword.other.metadata.atlx"],
          "controlKeyword": ["keyword.control.flow.atlx", "keyword.control.assert.atlx"],
          "functionKeyword": ["keyword.declaration.function.atlx"],
          "contractName": ["entity.name.type.contract.atlx"],
          "builtin": ["support.function.builtin.atlx"],
          "constant": ["constant.other.send-mode.atlx"],
          "messageName": ["variable.other.property.atlx"]
        }
      },
      {
        "language": "atlx",
        "scopes": {
          "property": ["entity.name.variable.contract-field.atlx", "variable.other.property.atlx"],
          "type": ["entity.name.type.struct.atlx", "entity.name.type.alias.atlx", "storage.type.builtin.atlx"],
          "function": ["entity.name.function.atlx"],
          "parameter": ["variable.parameter.atlx"],
          "variable": ["variable.other.readwrite.atlx"]
        }
      }
    ]
  },
  "configurationDefaults": {
    "[atlx]": {
      "editor.semanticHighlighting.enabled": true,
      "editor.semanticTokenColorCustomizations": {
        "enabled": true,
        "rules": {
          "annotation": "#41d7d1",
          "contractKeyword": "#f4c96b",
          "typeKeyword": "#8dff9f",
          "storageKeyword": "#c792ea",
          "metadataKeyword": "#41d7d1",
          "controlKeyword": "#41d7d1",
          "type": "#8dff9f",
          "contractName": "#f4c96b",
          "functionKeyword": "#f4c96b",
          "builtin": "#ffd166",
          "function": "#f4c96b",
          "parameter": "#b8f39b",
          "variable": "#8fd3c7",
          "property": "#8fd3c7",
          "constant": "#d8c6a0",
          "number": "#d8c6a0",
          "operator": "#c9d6ea",
          "comment": "#5d6f8e",
          "string": "#d8c6a0"
        }
      },
      "editor.tokenColorCustomizations": {
        "textMateRules": [
          {
            "scope": [
              "storage.type.annotation.atlx",
              "storage.type.annotation",
              "meta.annotation.atlx",
              "meta.annotation",
              "keyword.annotation.atlx"
            ],
            "settings": {
              "foreground": "#41d7d1"
            }
          },
          {
            "scope": [
              "string.quoted.double.atlx",
              "string.quoted.single.atlx",
              "string"
            ],
            "settings": {
              "foreground": "#d8c6a0"
            }
          },
          {
            "scope": [
              "keyword.other.metadata.atlx",
              "meta.declaration.metadata.atlx"
            ],
            "settings": {
              "foreground": "#41d7d1"
            }
          },
          {
            "scope": [
              "entity.name.type.contract.atlx",
              "keyword.declaration.contract.atlx"
            ],
            "settings": {
              "foreground": "#f4c96b"
            }
          },
          {
            "scope": [
              "entity.name.type.struct.atlx",
              "entity.name.type.alias.atlx",
              "storage.type.builtin.atlx"
            ],
            "settings": {
              "foreground": "#8dff9f"
            }
          },
          {
            "scope": [
              "keyword.declaration.type.atlx"
            ],
            "settings": {
              "foreground": "#ffb86b"
            }
          },
          {
            "scope": [
              "entity.name.function.atlx",
              "keyword.declaration.function.atlx"
            ],
            "settings": {
              "foreground": "#f4c96b"
            }
          },
          {
            "scope": [
              "keyword.declaration.storage.atlx"
            ],
            "settings": {
              "foreground": "#c792ea"
            }
          },
          {
            "scope": [
              "entity.name.variable.contract-field.atlx",
              "variable.other.property.atlx",
              "meta.declaration.contract-field.atlx"
            ],
            "settings": {
              "foreground": "#8fd3c7"
            }
          },
          {
            "scope": [
              "support.function.builtin.atlx"
            ],
            "settings": {
              "foreground": "#ffd166"
            }
          }
        ]
      }
    }
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -w -p .",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.28.0",
    "@types/node": "^22.16.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.9.2"
  }
}
