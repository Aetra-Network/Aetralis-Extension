{
  "name": "aetralis-language",
  "displayName": "Aetralis Language",
  "description": "Language extension for Aetralis smart contract development on the Aetra blockchain.",
  "version": "0.1.1",
  "publisher": "softwaremaestro",
  "repository": {
    "type": "git",
    "url": "https://github.com/Aetra-Network/Aetralis-Extension.git"
  },
  "bugs": {
    "url": "https://github.com/Aetra-Network/Aetralis-Extension/issues"
  },
  "homepage": "https://github.com/Aetra-Network/Aetralis-Extension#readme",
  "icon": "./assets/aetralis.png",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "aetralis",
    "atlx",
    "smart-contracts",
    "blockchain",
    "syntax-highlighting"
  ],
  "activationEvents": [
    "onLanguage:atlx"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -w -p .",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.28.0",
    "@types/node": "^22.16.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.9.2"
  },
  "contributes": {
    "languages": [
      {
        "id": "atlx",
        "aliases": [
          "Aetralis",
          "ATLX"
        ],
        "extensions": [
          ".atlx"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "atlx",
        "scopeName": "source.atlx",
        "path": "./syntaxes/atlx.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "atlx",
        "path": "./snippets/atlx.json"
      }
    ],
    "themes": [
      {
        "label": "Aetralis Ocean",
        "uiTheme": "vs-dark",
        "path": "./themes/aetralis-ocean-color-theme.json"
      }
    ]
  }
}
