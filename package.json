{
  "name": "aetralis-language",
  "displayName": "Aetralis Language",
  "description": "Syntax highlighting, autocompletion, hover help, diagnostics, and snippets for the Aetralis language.",
  "version": "0.1.18",
  "publisher": "softwaremaestro",
  "repository": {
    "type": "git",
    "url": "https://github.com/Aetra-Network/Aetralis-Extension.git"
  },
  "bugs": {
    "url": "https://github.com/Aetra-Network/Aetralis-Extension/issues"
  },
  "homepage": "https://github.com/Aetra-Network/Aetralis-Extension#readme",
  "icon": "./assets/atlx.png",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "aetralis",
    "atlx",
    "smart-contracts",
    "blockchain",
    "syntax-highlighting"
  ],
  "activationEvents": [
    "onLanguage:atlx"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "atlx",
        "aliases": [
          "Aetralis",
          "ATLX"
        ],
        "extensions": [
          ".atlx"
        ],
        "icon": {
          "light": "./assets/atlx.png",
          "dark": "./assets/atlx.png"
        },
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "atlx",
        "scopeName": "source.atlx",
        "path": "./syntaxes/atlx.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "atlx",
        "path": "./snippets/atlx.json"
      }
    ],
    "semanticTokenTypes": [
      {
        "id": "annotation",
        "superType": "decorator",
        "description": "Annotation tokens."
      },
      {
        "id": "declarationKeyword",
        "superType": "keyword",
        "description": "Declaration and ABI keywords."
      },
      {
        "id": "controlKeyword",
        "superType": "keyword",
        "description": "Control-flow keywords."
      },
      {
        "id": "abortKeyword",
        "superType": "keyword",
        "description": "Assertion and abort keywords."
      },
      {
        "id": "bindingKeyword",
        "superType": "keyword",
        "description": "Binding and mutation keywords."
      },
      {
        "id": "sideEffectKeyword",
        "superType": "keyword",
        "description": "Side-effect keywords."
      },
      {
        "id": "deprecated",
        "superType": "keyword",
        "description": "Deprecated compatibility surface."
      },
      {
        "id": "type",
        "superType": "type",
        "description": "A declared type name."
      },
      {
        "id": "builtinType",
        "superType": "type",
        "description": "A built-in runtime type."
      },
      {
        "id": "contractName",
        "superType": "class",
        "description": "A contract symbol."
      },
      {
        "id": "builtin",
        "superType": "function",
        "description": "A built-in helper."
      },
      {
        "id": "function",
        "superType": "function",
        "description": "A user-defined function."
      },
      {
        "id": "parameter",
        "superType": "variable",
        "description": "A function parameter."
      },
      {
        "id": "variable",
        "superType": "variable",
        "description": "A local variable."
      },
      {
        "id": "property",
        "superType": "property",
        "description": "A field or property."
      },
      {
        "id": "constant",
        "superType": "variable",
        "description": "A named constant."
      },
      {
        "id": "enumMember",
        "superType": "enumMember",
        "description": "An enum or message variant."
      },
      {
        "id": "number",
        "superType": "number",
        "description": "A numeric literal."
      },
      {
        "id": "operator",
        "superType": "operator",
        "description": "An operator token."
      }
    ],
    "semanticTokenScopes": [
      {
        "scopes": {
          "annotation": ["entity.other.attribute-name.atlx", "storage.type.annotation.atlx"],
          "declarationKeyword": [
            "keyword.declaration.atlx",
            "keyword.declaration.package.atlx",
            "keyword.declaration.import.atlx",
            "keyword.declaration.contract.atlx",
            "keyword.declaration.type.atlx",
            "keyword.declaration.struct.atlx",
            "keyword.declaration.enum.atlx",
            "keyword.declaration.func.atlx",
            "keyword.declaration.storage.atlx",
            "keyword.declaration.deploy.atlx",
            "keyword.declaration.message.atlx",
            "keyword.declaration.getter.atlx",
            "keyword.declaration.event.atlx",
            "keyword.declaration.wallet.atlx",
            "keyword.declaration.action.atlx",
            "keyword.declaration.namespace.atlx",
            "keyword.declaration.chain.atlx",
            "keyword.declaration.deployer.atlx",
            "keyword.declaration.salt.atlx",
            "keyword.declaration.initial-balance.atlx",
            "keyword.declaration.selector.atlx",
            "keyword.declaration.version.atlx",
            "keyword.declaration.alias.atlx"
          ],
          "controlKeyword": ["keyword.control.atlx", "keyword.control.flow.atlx"],
          "abortKeyword": ["keyword.control.assert.atlx", "keyword.control.throw.atlx"],
          "bindingKeyword": ["keyword.declaration.binding.atlx", "storage.modifier.binding.atlx"],
          "sideEffectKeyword": ["keyword.other.side-effect.atlx", "keyword.declaration.side-effect.atlx"],
          "deprecated": ["invalid.deprecated.atlx", "keyword.deprecated.atlx"],
          "builtinType": ["storage.type.builtin.atlx"],
          "contractName": ["entity.name.type.contract.atlx"],
          "builtin": ["support.function.builtin.atlx"],
          "constant": ["constant.other.symbol.atlx"],
          "enumMember": ["constant.other.enum.atlx", "constant.other.message.atlx"]
        }
      },
      {
        "language": "atlx",
        "scopes": {
          "type": ["entity.name.type.struct.atlx", "entity.name.type.alias.atlx", "entity.name.type.enum.atlx"],
          "function": ["entity.name.function.atlx"],
          "parameter": ["variable.parameter.atlx"],
          "variable": ["variable.other.readwrite.atlx"],
          "property": ["entity.name.variable.contract-field.atlx", "variable.other.property.atlx"],
          "number": ["constant.numeric.integer.atlx"],
          "operator": ["keyword.operator.arithmetic.atlx", "keyword.operator.comparison.atlx", "keyword.operator.logical.atlx", "keyword.operator.arrow.atlx"]
        }
      }
    ]
  },
  "configurationDefaults": {
    "[atlx]": {
      "editor.semanticHighlighting.enabled": true,
      "editor.semanticTokenColorCustomizations": {
        "enabled": true,
        "rules": {
          "annotation": "#56b6c2",
          "declarationKeyword": "#c678dd",
          "controlKeyword": "#e06c75",
          "abortKeyword": "#e06c75",
          "bindingKeyword": "#e5c07b",
          "sideEffectKeyword": "#56b6c2",
          "deprecated": "#7f848e",
          "type": "#61afef",
          "builtinType": "#61afef",
          "contractName": "#61afef",
          "builtin": "#56b6c2",
          "function": "#d19a66",
          "parameter": "#e5c07b",
          "variable": "#abb2bf",
          "property": "#abb2bf",
          "constant": "#98c379",
          "enumMember": "#98c379",
          "number": "#98c379",
          "operator": "#7f848e",
          "comment": "#5c6370",
          "string": "#d8c6a0"
        }
      },
      "editor.tokenColorCustomizations": {
        "textMateRules": [
          {
            "scope": [
              "entity.other.attribute-name.atlx",
              "storage.type.annotation.atlx",
              "storage.type.annotation",
              "meta.annotation.atlx",
              "meta.annotation",
              "keyword.annotation.atlx"
            ],
            "settings": {
              "foreground": "#56b6c2"
            }
          },
          {
            "scope": [
              "string.quoted.double.atlx",
              "string.quoted.single.atlx",
              "string"
            ],
            "settings": {
              "foreground": "#d8c6a0"
            }
          },
          {
            "scope": [
              "entity.other.attribute-name.atlx",
              "entity.name.variable.contract-field.atlx"
            ],
            "settings": {
              "foreground": "#abb2bf"
            }
          },
          {
            "scope": [
              "entity.name.type.contract.atlx"
            ],
            "settings": {
              "foreground": "#61afef"
            }
          },
          {
            "scope": [
              "keyword.declaration.atlx",
              "keyword.declaration.package.atlx",
              "keyword.declaration.import.atlx",
              "keyword.declaration.contract.atlx",
              "keyword.declaration.type.atlx",
              "keyword.declaration.struct.atlx",
              "keyword.declaration.enum.atlx",
              "keyword.declaration.func.atlx",
              "keyword.declaration.storage.atlx",
              "keyword.declaration.deploy.atlx",
              "keyword.declaration.message.atlx",
              "keyword.declaration.getter.atlx",
              "keyword.declaration.event.atlx",
              "keyword.declaration.wallet.atlx",
              "keyword.declaration.action.atlx",
              "keyword.declaration.namespace.atlx",
              "keyword.declaration.chain.atlx",
              "keyword.declaration.deployer.atlx",
              "keyword.declaration.salt.atlx",
              "keyword.declaration.initial-balance.atlx",
              "keyword.declaration.selector.atlx",
              "keyword.declaration.version.atlx",
              "keyword.declaration.alias.atlx"
            ],
            "settings": {
              "foreground": "#c678dd"
            }
          },
          {
            "scope": [
              "keyword.control.atlx",
              "keyword.control.flow.atlx",
              "keyword.control.assert.atlx",
              "keyword.control.throw.atlx"
            ],
            "settings": {
              "foreground": "#e06c75"
            }
          },
          {
            "scope": [
              "keyword.declaration.binding.atlx",
              "storage.modifier.binding.atlx"
            ],
            "settings": {
              "foreground": "#e5c07b"
            }
          },
          {
            "scope": [
              "keyword.other.side-effect.atlx",
              "keyword.declaration.side-effect.atlx"
            ],
            "settings": {
              "foreground": "#56b6c2"
            }
          },
          {
            "scope": [
              "invalid.deprecated.atlx",
              "keyword.deprecated.atlx"
            ],
            "settings": {
              "foreground": "#7f848e"
            }
          },
          {
            "scope": [
              "entity.name.type.struct.atlx",
              "entity.name.type.alias.atlx",
              "entity.name.type.enum.atlx"
            ],
            "settings": {
              "foreground": "#61afef"
            }
          },
          {
            "scope": [
              "storage.type.builtin.atlx"
            ],
            "settings": {
              "foreground": "#61afef"
            }
          },
          {
            "scope": [
              "entity.name.function.atlx"
            ],
            "settings": {
              "foreground": "#d19a66"
            }
          },
          {
            "scope": [
              "variable.parameter.atlx"
            ],
            "settings": {
              "foreground": "#e5c07b"
            }
          },
          {
            "scope": [
              "variable.other.readwrite.atlx",
              "entity.name.variable.contract-field.atlx",
              "variable.other.property.atlx",
              "meta.declaration.contract-field.atlx"
            ],
            "settings": {
              "foreground": "#abb2bf"
            }
          },
          {
            "scope": [
              "constant.other.symbol.atlx",
              "constant.other.enum.atlx",
              "constant.numeric.integer.atlx"
            ],
            "settings": {
              "foreground": "#98c379"
            }
          },
          {
            "scope": [
              "support.function.builtin.atlx"
            ],
            "settings": {
              "foreground": "#56b6c2"
            }
          }
        ]
      }
    }
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -w -p .",
    "test": "node --test test/analyzer.test.js test/package.test.js",
    "vscode:prepublish": "npm run compile",
    "package": "npx vsce package --no-dependencies --out aetralis-language.vsix"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.28.0",
    "@types/node": "^22.16.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.9.2"
  }
}
