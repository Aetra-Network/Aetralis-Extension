{
  "name": "Aetralis Ocean",
  "type": "dark",
  "colors": {
    "editor.background": "#09111f",
    "editor.foreground": "#dbe7ff",
    "editorLineNumber.foreground": "#42506f",
    "editorLineNumber.activeForeground": "#8ea6d8",
    "editorIndentGuide.background1": "#1d2740",
    "editorIndentGuide.activeBackground1": "#35507d",
    "editor.selectionBackground": "#24324f",
    "editor.inactiveSelectionBackground": "#1a2339",
    "editor.lineHighlightBackground": "#0e1729",
    "editorCursor.foreground": "#8de0da"
  },
  "semanticTokenColors": {
    "comment": "#5d6f8e",
    "string": "#b7e59e",
    "annotation": "#41d7d1",
    "contractKeyword": "#8ab4ff",
    "typeKeyword": "#ffb86b",
    "storageKeyword": "#c792ea",
    "assertKeyword": "#c792ea",
    "controlKeyword": "#58a6ff",
    "type": "#8dff9f",
    "contractName": "#9bd8ff",
    "functionKeyword": "#ff9f6e",
    "builtin": "#ffd166",
    "function": "#f4c96b",
    "parameter": "#b8f39b",
    "variable": "#c8f1b9",
    "property": "#8fd3c7",
    "messageName": "#8dff9f",
    "constant": "#ffd27a",
    "number": "#ffd27a",
    "operator": "#9bb0d8"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "comment.line",
        "comment.block",
        "comment.line.documentation",
        "comment.block.documentation"
      ],
      "settings": {
        "foreground": "#5d6f8e",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted.double",
        "string.quoted.single"
      ],
      "settings": {
        "foreground": "#b7e59e"
      }
    },
    {
      "scope": [
        "storage.type.annotation.atlx",
        "storage.type.annotation"
      ],
      "settings": {
        "foreground": "#41d7d1"
      }
    },
    {
      "scope": [
        "entity.name.type.contract.atlx"
      ],
      "settings": {
        "foreground": "#9bd8ff"
      }
    },
    {
      "scope": [
        "entity.name.type.struct.atlx",
        "entity.name.type.alias.atlx",
        "storage.type.builtin.atlx"
      ],
      "settings": {
        "foreground": "#8dff9f"
      }
    },
    {
      "scope": [
        "entity.name.function.atlx"
      ],
      "settings": {
        "foreground": "#f4c96b"
      }
    },
    {
      "scope": [
        "keyword.declaration.contract.atlx"
      ],
      "settings": {
        "foreground": "#8ab4ff"
      }
    },
    {
      "scope": [
        "keyword.declaration.type.atlx"
      ],
      "settings": {
        "foreground": "#ffb86b"
      }
    },
    {
      "scope": [
        "keyword.declaration.storage.atlx",
        "keyword.control.assert.atlx"
      ],
      "settings": {
        "foreground": "#c792ea"
      }
    },
    {
      "scope": [
        "keyword.declaration.function.atlx"
      ],
      "settings": {
        "foreground": "#ff9f6e"
      }
    },
    {
      "scope": [
        "keyword.control.flow.atlx"
      ],
      "settings": {
        "foreground": "#58a6ff"
      }
    },
    {
      "scope": [
        "keyword.other.metadata.atlx"
      ],
      "settings": {
        "foreground": "#8fd3c7"
      }
    },
    {
      "scope": [
        "support.function.builtin.atlx"
      ],
      "settings": {
        "foreground": "#ffd166"
      }
    },
    {
      "scope": [
        "variable.other.property.atlx"
      ],
      "settings": {
        "foreground": "#8fd3c7"
      }
    },
    {
      "scope": [
        "constant.language.boolean.atlx",
        "constant.language.null.atlx",
        "constant.numeric.integer.atlx",
        "constant.other.send-mode.atlx"
      ],
      "settings": {
        "foreground": "#ffd27a"
      }
    }
  ]
}
