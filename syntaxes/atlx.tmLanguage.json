{
  "name": "Aetralis",
  "scopeName": "source.atlx",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#compatibilityAnnotations" },
    { "include": "#annotations" },
    { "include": "#contractFields" },
    { "include": "#metadata" },
    { "include": "#declarations" },
    { "include": "#compatibilityKeywords" },
    { "include": "#keywords" },
    { "include": "#members" },
    { "include": "#builtins" },
    { "include": "#types" },
    { "include": "#literals" },
    { "include": "#numbers" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.documentation.atlx",
          "match": "///.*$"
        },
        {
          "name": "comment.line.double-slash.atlx",
          "match": "//.*$"
        },
        {
          "name": "comment.block.documentation.atlx",
          "begin": "/\\*\\*",
          "end": "\\*/"
        },
        {
          "name": "comment.block.atlx",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.atlx",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.atlx",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.atlx",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.atlx",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "compatibilityAnnotations": {
      "patterns": [
        {
          "name": "invalid.deprecated.atlx",
          "match": "@store\\b"
        }
      ]
    },
    "annotations": {
      "patterns": [
        {
          "name": "entity.other.attribute-name.atlx",
          "match": "@[A-Za-z_][A-Za-z0-9_]*(?:\\([^\\n\\r]*?\\))?"
        }
      ]
    },
    "metadata": {
      "patterns": [
        {
          "name": "entity.name.variable.contract-field.atlx",
          "match": "\\b(?:author|description|version)\\b"
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "name": "meta.declaration.contract.atlx",
          "match": "\\bcontract\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "entity.name.type.contract.atlx"
            }
          }
        },
        {
          "name": "meta.declaration.struct.atlx",
          "match": "\\bstruct\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "entity.name.type.struct.atlx"
            }
          }
        },
        {
          "name": "meta.declaration.enum.atlx",
          "match": "\\benum\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "entity.name.type.enum.atlx"
            }
          }
        },
        {
          "name": "meta.declaration.type-alias.atlx",
          "match": "\\btype\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*=",
          "captures": {
            "1": {
              "name": "entity.name.type.alias.atlx"
            }
          }
        },
        {
          "name": "meta.declaration.function.atlx",
          "match": "\\bfunc\\s+(?:(?:[A-Za-z_][A-Za-z0-9_]*)\\.)?([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "entity.name.function.atlx"
            }
          }
        }
      ]
    },
    "contractFields": {
      "patterns": [
        {
          "name": "meta.declaration.contract-field.atlx",
          "match": "^(\\s*)([A-Za-z_][A-Za-z0-9_]*)\\s*:",
          "captures": {
            "2": {
              "name": "entity.name.variable.contract-field.atlx"
            }
          }
        }
      ]
    },
    "compatibilityKeywords": {
      "patterns": [
        {
          "name": "invalid.deprecated.atlx",
          "match": "\\b(?:let|val|mut|slice|cell|isSlice|isSliceSignatureValid|getData|setData|createMessage|commit|skipBouncedPrefix|fromSegment|isEmpty|send)\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.declaration.atlx",
          "match": "\\b(?:package|import|contract|struct|enum|type|func|storage|deploy|message|getter|event|wallet|action|namespace|chain|deployer|salt|initial_balance|selector|version|as)\\b"
        },
        {
          "name": "keyword.control.atlx",
          "match": "\\b(?:if|else|while|do|repeat|for|in|to|match|case|return|break|continue)\\b"
        },
        {
          "name": "keyword.control.assert.atlx",
          "match": "\\b(?:assert|throw)\\b"
        },
        {
          "name": "keyword.declaration.binding.atlx",
          "match": "\\b(?:const|var|lazy|mutate|self|set)\\b"
        },
        {
          "name": "keyword.other.side-effect.atlx",
          "match": "\\b(?:emit|send|refund)\\b"
        }
      ]
    },
    "members": {
      "patterns": [
        {
          "name": "variable.other.property.atlx",
          "match": "\\.([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "variable.other.property.atlx"
            }
          }
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.builtin.atlx",
          "match": "\\b(?:buildMessage|counterfactualAddress|autoDeployAddress|getAddress|getOriginalBalance|getAttachedValue|getCode|setCodePostponed|now|logicalTime|currentBlockLogicalTime|random|isSignatureValid|fromChunk|toChunk|address|aet)\\b"
        },
        {
          "name": "support.function.builtin.atlx",
          "match": "\\b(?:random\\.(?:initialize|initializeBy|uint256|range|getSeed|setSeed)|Code\\.(?:fromHex|fromBase64|fromChunk|hash|toChunk)|Chunk\\.(?:fromHex|hash)|Segment\\.hash|segment\\.bitsHash)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.builtin.atlx",
          "match": "\\b(?:string|bool|uint8|uint16|uint32|uint64|uint128|uint256|u8|u16|u32|u64|u128|u256|int8|int16|int32|int64|int128|int256|i8|i16|i32|i64|i128|i256|coins|address|bytes|hash32|hash|code|chunk|segment|stateinit|timestamp|List|Map|Dict|MapEntry|Option|Result|Chunk|ChunkRef|ChunkLink|ChunkCursor|Code|Segment|StateInit|Address|Hash|Bytes|Coins|Timestamp|Storage|InMessage|InMessageBounced|ContractContext|MessageEnvelope)\\b"
        }
      ]
    },
    "literals": {
      "patterns": [
        {
          "name": "constant.language.boolean.atlx",
          "match": "\\b(?:true|false)\\b"
        },
        {
          "name": "constant.language.null.atlx",
          "match": "\\bnull\\b"
        },
        {
          "name": "constant.language.send-mode.atlx",
          "match": "\\b(?:SEND_DEFAULT|SEND_CARRY_REMAINDER|SEND_DRAIN_BALANCE|SEND_ESTIMATE_ONLY|SEND_FEE_FROM_BALANCE|SEND_IGNORE_ERRORS|SEND_BOUNCE_ON_FAIL|SEND_DESTROY_IF_EMPTY|SEND_MODE_REGULAR|SEND_MODE_CARRY_ALL_REMAINING_MESSAGE_VALUE|SEND_MODE_CARRY_ALL_BALANCE|SEND_MODE_ESTIMATE_FEE_ONLY|SEND_MODE_PAY_FEES_SEPARATELY|SEND_MODE_IGNORE_ERRORS|SEND_MODE_BOUNCE_ON_ACTION_FAIL|SEND_MODE_DESTROY)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.integer.atlx",
          "match": "\\b0x[0-9A-Fa-f]+\\b"
        },
        {
          "name": "constant.numeric.integer.atlx",
          "match": "\\b\\d(?:_?\\d)*\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arithmetic.atlx",
          "match": "[+\\-*/%]"
        },
        {
          "name": "keyword.operator.comparison.atlx",
          "match": "(?:==|!=|<=|>=|=|<|>)"
        },
        {
          "name": "keyword.operator.logical.atlx",
          "match": "(?:&&|\\|\\||!)"
        },
        {
          "name": "keyword.operator.arrow.atlx",
          "match": "(?:->|=>)"
        },
        {
          "name": "punctuation.section.block.begin.atlx",
          "match": "[\\[\\(\\{]"
        },
        {
          "name": "punctuation.section.block.end.atlx",
          "match": "[\\]\\)\\}]"
        },
        {
          "name": "punctuation.separator.atlx",
          "match": "[:,.;]"
        }
      ]
    }
  }
}
